<!-- pages/custom-wordbank/index.wxml -->
<view class="cw-page">

  <!-- 自定义导航栏 -->
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="custom-nav-bar" style="height: {{navBarHeight}}px; padding-right: {{navRightPadding}}px">
      <navigator class="nav-back" open-type="navigateBack">‹</navigator>
      <text class="nav-title">{{pageState === 'done' ? '创建成功' : '创建词库'}}</text>
      <view class="nav-placeholder"></view>
    </view>
  </view>
  <view style="height: {{statusBarHeight + navBarHeight}}px"></view>

  <!-- Toast -->
  <view class="cw-toast {{toastType}}" wx:if="{{toast}}">
    <text class="cw-toast-text">{{toast}}</text>
  </view>

  <!-- ══ 编辑状态 ══ -->
  <block wx:if="{{pageState === 'edit'}}">

    <!-- 词库名称 -->
    <view class="field-card">
      <text class="field-label">词库名称</text>
      <input
        class="field-input"
        placeholder="给词库起个名字（最多20字）"
        placeholder-class="field-placeholder"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>

    <!-- 创建者昵称 + 允许编辑 -->
    <view class="field-card">
      <text class="field-label">创建者昵称</text>
      <input
        class="field-input"
        placeholder="选填，显示给订阅者看（最多10字）"
        placeholder-class="field-placeholder"
        value="{{creatorName}}"
        bindinput="onCreatorNameInput"
        maxlength="10"
      />
      <view class="field-row-switch">
        <view class="field-switch-label">
          <text class="field-switch-title">允许他人编辑</text>
          <text class="field-switch-desc">开启后，订阅者可提交新词条</text>
        </view>
        <view class="cw-switch" catchtap="toggleAllowEdit">
          <view class="switch-track {{allowEdit ? 'on' : 'off'}}">
            <view class="switch-thumb"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 添加词条 -->
    <view class="field-card">
      <view class="field-label-row">
        <text class="field-label">词条</text>
        <text class="word-counter {{words.length >= 100 ? 'full' : ''}}">{{words.length}} / 100</text>
      </view>
      <view class="add-word-row">
        <input
          class="word-input"
          placeholder="输入一个词，回车添加"
          placeholder-class="field-placeholder"
          value="{{inputWord}}"
          bindinput="onWordInput"
          bindconfirm="addWord"
          maxlength="10"
          confirm-type="done"
        />
        <view class="btn-add-word {{inputWord ? '' : 'disabled'}}" catchtap="addWord">
          <text class="btn-add-text">添加</text>
        </view>
      </view>
      <text class="field-tip">至少添加 5 个词；每词不超过 10 字；点击词条可删除</text>
    </view>

    <!-- 词条展示区 -->
    <view class="words-area" wx:if="{{words.length > 0}}">
      <view
        class="word-tag"
        wx:for="{{words}}"
        wx:key="*this"
        catchtap="removeWord"
        data-index="{{index}}"
      >
        <text class="word-tag-text">{{item}}</text>
        <text class="word-tag-del">×</text>
      </view>
    </view>
    <view class="words-empty" wx:else>
      <text class="words-empty-text">还没有添加任何词条</text>
    </view>

    <!-- 提交按钮 -->
    <button
      class="btn-submit {{(submitting || words.length < 5 || !name) ? 'disabled' : ''}}"
      catchtap="submitWordbank"
    >
      <text wx:if="{{submitting}}">正在创建…</text>
      <text wx:else>🚀 生成分享码</text>
    </button>

    <view style="height: 60rpx"></view>
  </block>

  <!-- ══ 完成状态 ══ -->
  <block wx:if="{{pageState === 'done'}}">
    <view class="done-card">
      <text class="done-icon">🎉</text>
      <text class="done-title">词库已创建！</text>
      <text class="done-name">「{{name}}」</text>
      <text class="done-count">共 {{words.length}} 个词条</text>

      <!-- 分享码展示 -->
      <view class="sharecode-box" bindtap="copyShareCode">
        <text class="sharecode-label">分享码</text>
        <text class="sharecode-value">{{shareCode}}</text>
        <text class="sharecode-copy">点击复制</text>
      </view>

      <text class="done-tip">将分享码发给朋友，对方在词库设置页输入即可订阅</text>
    </view>

    <!-- 操作按钮 -->
    <button class="btn-share" open-type="share">📤 分享给朋友</button>
    <button class="btn-back" bindtap="goBack">← 返回词库设置</button>

    <view style="height: 60rpx"></view>
  </block>

</view>
