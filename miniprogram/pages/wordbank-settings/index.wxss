/* pages/wordbank-settings/index.wxss */

.ws-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
  padding: 24rpx 28rpx 80rpx;
  box-sizing: border-box;
  color: #fff;
}

/* ── 导航栏 ─── */
.custom-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: #1a1a2e;
  z-index: 200;
}
.custom-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
}
.nav-back {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
  opacity: 0.85;
  flex: 1;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  text-align: center;
}
.nav-placeholder { flex: 1; }

/* ── Toast ─── */
.ws-toast {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.78);
  border-radius: 48rpx;
  padding: 20rpx 44rpx;
  z-index: 500;
  max-width: 80%;
  text-align: center;
  white-space: nowrap;
}
.ws-toast-text {
  font-size: 28rpx;
  color: #fff;
}

/* ── Section 标题 ─── */
.section-title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  letter-spacing: 2rpx;
  margin: 20rpx 4rpx 12rpx;
  text-transform: uppercase;
}

/* ── 分组块 ─── */
.group-block {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
}

.group-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.difficulty-badge {
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 12rpx;
  padding: 4rpx 18rpx;
}
.diff-easy   { background: rgba(39,174,96,0.25);  color: #7dcea0; }
.diff-medium { background: rgba(52,152,219,0.25); color: #85c1e9; }
.diff-hard   { background: rgba(233,69,96,0.25);  color: #f1948a; }

.group-count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

.group-toggle-btn {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
}

.group-toggle-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
}

/* ── 分类列表 ─── */
.category-list {
  padding: 8rpx 16rpx 12rpx;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 4rpx;
  transition: background 0.15s;
}

.category-item.checked {
  background: rgba(233,69,96,0.12);
}

.cat-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.cat-count {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, border-color 0.15s;
}

.checkbox.checked {
  background: #e94560;
  border-color: #e94560;
}

.check-mark {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
}

/* ── 订阅列表 ─── */
.sub-list {
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.sub-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.07);
  gap: 16rpx;
}

.sub-item:last-child { border-bottom: none; }

.sub-switch { flex-shrink: 0; }

.switch-track {
  width: 88rpx;
  height: 48rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  padding: 0 6rpx;
  box-sizing: border-box;
  transition: background 0.2s;
}
.switch-track.on  { background: #e94560; justify-content: flex-end; }
.switch-track.off { background: rgba(255,255,255,0.15); justify-content: flex-start; }

.switch-thumb {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
}

.sub-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.sub-meta {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

.sub-del {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.sub-empty {
  padding: 40rpx 0;
  text-align: center;
}

.sub-empty-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.3);
}

/* ── 分享码输入 ─── */
.subscribe-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.code-input {
  flex: 1;
  height: 88rpx;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #fff;
  letter-spacing: 4rpx;
  box-sizing: border-box;
}

.code-input-placeholder {
  color: rgba(255,255,255,0.3);
  letter-spacing: 0;
}

.btn-subscribe {
  height: 88rpx;
  min-width: 120rpx;
  background: linear-gradient(135deg, #e94560, #c0392b);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(233,69,96,0.35);
}

.btn-subscribe text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.btn-subscribe.disabled {
  opacity: 0.5;
}

/* ── 创建按钮 ─── */
.create-btn-wrap {
  margin-top: 16rpx;
}

.btn-create {
  width: 100%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.75);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 56rpx;
  padding: 28rpx 0;
}

.btn-create:active { opacity: 0.7; }
